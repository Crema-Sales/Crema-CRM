JWT_SECRET=dev-jwt-secret-replace-in-prod
INGEST_WEBHOOK_SECRET=dev-ingest-secret-replace-in-prod

# RepAgent backend (chat WS + REST API). Must match wherever ctrl-alt-elite-agent
# is reachable. Defaults to localhost:8787 if unset.
VITE_API_BASE=https://ctrl-alt-elite-agent.smashlabs.workers.dev

# Agentic enrichment (Settings → Prompts). Set via `wrangler secret put` in prod.
# Without OPENROUTER_API_KEY, auto-enrichment skips silently (logs a warning).
# Without TAVILY_API_KEY, the agent falls back to fetching the company's
# homepage only — no web search.
OPENROUTER_API_KEY=
TAVILY_API_KEY=
