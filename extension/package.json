{
  "name": "crema-agent-extension",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "Rep-side agent control surface for Crema Sales (MV3).",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run scripts/build.ts --watch",
    "typecheck": "tsc --noEmit",
    "test:integration": "bun run scripts/integration/run-all.ts",
    "test:health": "bun run scripts/integration/health-check.ts",
    "test:mint": "bun run scripts/integration/mint-token.ts",
    "test:status": "bun run scripts/integration/status-check.ts",
    "test:ws": "bun run scripts/integration/ws-smoke.ts",
    "test:act": "bun run scripts/integration/act-roundtrip.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.0.279",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  }
}
