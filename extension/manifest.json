{
  "manifest_version": 3,
  "name": "Crema Sales Agent",
  "version": "0.2.0",
  "description": "Rep-side agent control surface for Crema Sales.",
  "key": "",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/agent-on-128.png",
      "32": "icons/agent-on-128.png",
      "48": "icons/agent-on-128.png",
      "128": "icons/agent-on-128.png"
    },
    "default_title": "Crema Sales Agent",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "activeTab",
    "debugger",
    "webRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.live.com/*",
        "https://www.linkedin.com/*",
        "https://teams.microsoft.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://cremasales.com/*",
      "https://*.cremasales.com/*",
      "http://localhost:*/*"
    ]
  },
  "icons": {
    "16": "icons/agent-off-128.png",
    "32": "icons/agent-off-128.png",
    "48": "icons/agent-off-128.png",
    "128": "icons/agent-off-128.png"
  }
}
